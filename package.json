{
  "name": "talpa-dpg-2026",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/",
    "test:unit:validation": "vitest run src/lib/validation.test.js",
    "test:unit:hook": "vitest run src/hooks/useApplicationForm.test.jsx",
    "test:integration": "vitest run tests/integration/",
    "test:stress": "node tests/stress/quota-race.test.js --users=200 --wave=50",
    "test:stress:mock": "vitest run tests/stress/quota-race-mock.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "playwright test e2e/admin-auth.spec.js",
    "test:e2e:form": "playwright test e2e/form-submit-complete.spec.js",
    "test:e2e:quota": "playwright test e2e/quota-full.spec.js",
    "test:security": "vitest run tests/integration/rls-security.test.js",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@supabase/supabase-js": "^2.97.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "react-router-dom": "^7.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.3.1",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "nodemailer": "^8.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
